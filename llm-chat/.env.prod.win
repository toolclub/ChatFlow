# ============================================================
# ChatFlow 生产覆盖配置（Windows 本地）
# 只含与 .env 不同的值，启动时与 .env 合并使用
# ENC() 密文全在 .env 里，这里不重复
# ============================================================

APP_VERSION=1.0.8

# 9800X3D 8 核高性能，IO 密集型设 8 worker
GUNICORN_WORKERS=8

# Windows 数据目录（与开发 .env 保持一致）
SECRET_DIR=D:/opt/secret
QDRANT_DATA_DIR=D:/docker/qdrant_storage
QDRANT_PORT=6333
POSTGRES_DATA_DIR=D:/docker/postgres_data
POSTGRES_PORT=5432
REDIS_DATA_DIR=D:/docker/redis_data
REDIS_PORT=6379
BACKEND_LOG_HOST_DIR=./logs
