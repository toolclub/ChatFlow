# ============================================================
# ChatFlow 配置模板
# 复制为 .env 并填入实际值后启动
# ============================================================

# ── 镜像版本控制 ─────────────────────────────────────────────
# 改这里触发重新构建新镜像；不改则 docker compose up 直接复用本地已有镜像
APP_VERSION=1.0.0

# ── LLM 服务（OpenAI 兼容接口）──────────────────────────────
# 本地 Ollama（Docker 内连宿主机）：http://host.docker.internal:11434/v1
# 本地 Ollama（宿主机直接运行）：  http://localhost:11434/v1
# OpenAI：                         https://api.openai.com/v1
LLM_BASE_URL=xxx
API_KEY=xxx
# Embedding 接口地址（必须含 /v1 路径）
# 本地 Ollama：  http://host.docker.internal:11434/v1
# OpenAI：       https://api.openai.com/v1
# GLM (智谱)：   https://open.bigmodel.cn/api/paas/v4
# MiniMax：      https://api.minimax.chat/v1
EMBEDDING_BASE_URL=xxx

# ── 模型 ─────────────────────────────────────────────────────
CHAT_MODEL=xxx
SUMMARY_MODEL=xxx
EMBEDDING_MODEL=xxx
# 视觉模型（上传图片时使用，需支持多模态），留空则使用 chat 路由模型
# 示例（Ollama 本地）：qwen2.5vl:7b / llava:13b
# 示例（OpenAI）：    gpt-4o / gpt-4-turbo
VISION_MODEL=
# 视觉模型的独立接口地址，默认复用 LLM_BASE_URL
# 示例（Docker 内连 Ollama）：http://host.docker.internal:11434/v1
# 示例（宿主机直接运行）：   http://localhost:11434/v1
VISION_BASE_URL=
# 视觉模型的独立 API Key，默认复用 API_KEY（Ollama 本地填 ollama 即可）
VISION_API_KEY=

# ── 路由 Agent ────────────────────────────────────────────────
ROUTER_ENABLED=true
ROUTER_MODEL=xxx
SEARCH_MODEL=xxx
# JSON 格式，按路由类型映射不同模型
ROUTE_MODEL_MAP={"code":"xxx","search":"xxx","chat":"xxx","search_code":"xxx"}

# ── 上下文窗口 ────────────────────────────────────────────────
CHAT_NUM_CTX=4096
SUMMARY_NUM_CTX=2048
FETCH_WEBPAGE_MAX_DISPLAY=500

# ── 记忆参数 ──────────────────────────────────────────────────
SHORT_TERM_MAX_TURNS=10
SHORT_TERM_FORGET_TURNS=2
COMPRESS_TRIGGER=8
MAX_SUMMARY_LENGTH=500

# ── 长期记忆（Qdrant）────────────────────────────────────────
LONGTERM_MEMORY_ENABLED=true
# Docker Compose 内部地址：http://qdrant:6333
# 宿主机直接运行：         http://localhost:6333
QDRANT_URL=xxx
QDRANT_COLLECTION=llm_chat_memories
EMBEDDING_DIM=1024
LONGTERM_TOP_K=3
LONGTERM_SCORE_THRESHOLD=0.5
SUMMARY_RELEVANCE_THRESHOLD=0.4

# ── 语义缓存（Redis Search）──────────────────────────────────
SEMANTIC_CACHE_ENABLED=true
# Docker Compose 内部地址：redis://redis:6379
# 宿主机直接运行：         redis://localhost:6379
REDIS_URL=xxx
SEMANTIC_CACHE_INDEX=semantic_cache
# 相似度阈值（0-1），推荐 0.85~0.92
SEMANTIC_CACHE_THRESHOLD=0.85
# user   = 按用户（client_id）隔离，多人系统推荐
# prompt = 按 system_prompt 跨用户共享
# global = 全局共享
# conv   = 按对话隔离（最细粒度）
SEMANTIC_CACHE_NAMESPACE_MODE=user
# search/search_code 缓存过期时间（小时），到期后重新联网搜索
SEMANTIC_CACHE_SEARCH_TTL_HOURS=12

# ── 数据库（PostgreSQL）──────────────────────────────────────
POSTGRES_DB=xxx
POSTGRES_USER=xxx
POSTGRES_PASSWORD=xxx
# Docker Compose 内部地址示例：postgresql://user:pass@postgres:5432/db
# 宿主机直接运行示例：         postgresql://user:pass@localhost:5432/db
DATABASE_URL=xxx

# ── 后端服务 ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# 容器内日志目录（与 docker-compose volumes 对应）
LOG_DIR=/var/log/chatflow
CONVERSATIONS_DIR=/app/conversations

# ── Docker 宿主机数据目录 & 端口 ─────────────────────────────
# 宿主机上持久化数据的存放路径（按本机实际路径填写）
QDRANT_DATA_DIR=xxx
QDRANT_PORT=6333
POSTGRES_DATA_DIR=xxx
POSTGRES_PORT=5432
REDIS_DATA_DIR=xxx
REDIS_PORT=6379
BACKEND_LOG_HOST_DIR=./logs

# ── MCP 服务器（JSON 格式，留空则不加载）─────────────────────
# MCP_SERVERS={"filesystem":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","./data"],"transport":"stdio"}}

