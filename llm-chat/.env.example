# ============================================================
# ChatFlow 配置文件示例
# 复制为 .env 并按需修改，所有字段均为可选（有默认值）
# ============================================================

# ── LLM 服务地址（OpenAI 兼容接口）──────────────────────────
# 本地 Ollama（默认）
LLM_BASE_URL=http://localhost:11434/v1
# Docker 容器内连接宿主机 Ollama（Windows/Mac Docker Desktop）
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# OpenAI
# LLM_BASE_URL=https://api.openai.com/v1

API_KEY=ollama
# OpenAI 填真实 Key:
# API_KEY=sk-xxxxxxxxxxxxxxxx

# Embedding 服务（Ollama 原生 API）
OLLAMA_BASE_URL=http://localhost:11434
# Docker 内:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── 模型 ──────────────────────────────────────────────────
CHAT_MODEL=qwen3:8b
SUMMARY_MODEL=qwen3:8b
EMBEDDING_MODEL=bge-m3

# ── 路由 Agent ────────────────────────────────────────────
ROUTER_ENABLED=true
ROUTER_MODEL=qwen3:8b
SEARCH_MODEL=qwen3:8b

# 路由模型映射（JSON 格式）
# ROUTE_MODEL_MAP={"code":"qwen3-coder:30b","search":"qwen3:8b","chat":"qwen3:8b","search_code":"qwen3-coder:30b"}

# ── 长期记忆（Qdrant）────────────────────────────────────
LONGTERM_MEMORY_ENABLED=true
QDRANT_URL=http://localhost:6333
# Docker Compose 内部地址：
# QDRANT_URL=http://qdrant:6333

QDRANT_COLLECTION=llm_chat_memories
EMBEDDING_DIM=1024
LONGTERM_TOP_K=3
LONGTERM_SCORE_THRESHOLD=0.5

# ── 记忆参数 ──────────────────────────────────────────────
SHORT_TERM_MAX_TURNS=10
COMPRESS_TRIGGER=8
MAX_SUMMARY_LENGTH=500

# ── 服务端口 ──────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── 持久化目录 ────────────────────────────────────────────
CONVERSATIONS_DIR=./conversations

# ── MCP 服务器（JSON 格式，留空则不加载）────────────────────
# MCP_SERVERS={"filesystem":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","./data"],"transport":"stdio"}}
