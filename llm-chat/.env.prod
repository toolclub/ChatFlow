# ============================================================
# ChatFlow 生产覆盖配置（Mac Mini 云端）
# 只含与 .env 不同的值，启动时与 .env 合并使用
# ENC() 密文全在 .env 里，这里不重复
# ============================================================

APP_VERSION=1.0.8

# Mac Mini M4（10 核）留 2 核给 OS+服务，设 4 worker
GUNICORN_WORKERS=4

# Mac 数据目录（start-mac.sh 自动创建）
SECRET_DIR=/opt/secret
QDRANT_DATA_DIR=/opt/chatflow-data/qdrant
QDRANT_PORT=6333
POSTGRES_DATA_DIR=/opt/chatflow-data/postgres
POSTGRES_PORT=5432
REDIS_DATA_DIR=/opt/chatflow-data/redis
REDIS_PORT=6379
BACKEND_LOG_HOST_DIR=/opt/chatflow-data/logs
