# ============================================================
# ChatFlow 生产覆盖配置（Mac Mini 云端）
# 只含与 .env 不同的值，启动时与 .env 合并使用
# ENC() 密文全在 .env 里，这里不重复
# ============================================================

APP_VERSION=1.0.8

# Mac Mini M4（10 核）留 2 核给 OS+服务，设 4 worker
GUNICORN_WORKERS=4

# MacBook 数据目录（$HOME 由 Docker Compose 从 shell 环境展开，无需写绝对路径）
SECRET_DIR=${HOME}/chatflow-data/secret
QDRANT_DATA_DIR=${HOME}/chatflow-data/qdrant
QDRANT_PORT=6333
POSTGRES_DATA_DIR=${HOME}/chatflow-data/postgres
POSTGRES_PORT=5432
REDIS_DATA_DIR=${HOME}/chatflow-data/redis
REDIS_PORT=6379
BACKEND_LOG_HOST_DIR=${HOME}/chatflow-data/logs
QUANT_CACHE_DATA_DIR=${HOME}/chatflow-data/quant_cache

# ── JWT 配置 ─────────────────────────────────────────────────────
JWT_SECRET_KEY=ENC(gAAAAABqGCLKZodwLe67Lr8YlYj6H22h79NniN9RWtZYsD2U_fdWSSSi8XkIFSrVlLBolEQWwNnnrdVdqeCz3jq9YfYCtOmwRrE_2Y_jraINUtvv-IP6yi51jtGoj4B8SIBToTtp_aqv)
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ── OAuth 配置（生产环境）────────────────────────────────────────
# Google OAuth（与开发共用）
OAUTH_GOOGLE_CLIENT_ID=ENC(gAAAAABqGCLKVl6GezJy0N8eFJRJnALhkBGHvQHApbVVM0Q9bP6sFgzImjO2CWrKVRgDGEy_TobkAN_nkfupdjULWl5OUpQLUZV_rki2eauPQeT4Lw_zm2CmnBkTRQel0clpH7aHnNbZLFScl_wcR4jec_9zK4b_G2EC1ka9kdI9dEZhLHghq7o=)
OAUTH_GOOGLE_CLIENT_SECRET=ENC(gAAAAABqGCLKefEeVBbingZHfYeqtr72KTOPfZc4EuWZi1f0mCIzD2HEGiugfe6_9mztqpfHbsw5ZdbqcreTlPhMAVRtKijEDrEZeWmN2QhY6jfQm7dsEest1tMaKNsEOefaEPdH76r8)
