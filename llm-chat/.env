# ============================================================
# ChatFlow 配置
# ============================================================

# ── 镜像版本控制 ─────────────────────────────────────────────
APP_VERSION=1.0.8

# ── LLM 服务 ─────────────────────────────────────────────────
LLM_BASE_URL=https://api.minimaxi.com/v1
API_KEY=ENC(gAAAAABp0e2Vsswm5fqdsBaeRlUSlh4ZN7d8PRjicXm6JolJAqUx5WGxYMGXnSBM2r-PuPZ7DejXkT2l24tTflgU3v3vyFiQuurqiHZtCZPaj3__ywW_OvgtjaEuNGhKhmc99UZH7Tvh3Z2bBHqxnLD5fCH7VhIGErBLaKmOK7zq8TTg_ye4YYeAmsv_9asSgfMImyYg2siH4uqbRsl7SrJ6SlblhqPkH8W-xTZ7etcgrU5zON3gdvs=)
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1

# ── 模型 ─────────────────────────────────────────────────────
CHAT_MODEL=MiniMax-M2.5
SUMMARY_MODEL=MiniMax-M2.5
EMBEDDING_MODEL=bge-m3

# ── 路由 Agent ────────────────────────────────────────────────
ROUTER_ENABLED=true
ROUTER_MODEL=MiniMax-M2.5
SEARCH_MODEL=MiniMax-M2.5
ROUTE_MODEL_MAP={"code":"MiniMax-M2.5","search":"MiniMax-M2.5","chat":"MiniMax-M2.5","search_code":"MiniMax-M2.5"}

# ── 上下文窗口 ────────────────────────────────────────────────
CHAT_NUM_CTX=8192
SUMMARY_NUM_CTX=4096
FETCH_WEBPAGE_MAX_DISPLAY=500

# ── 记忆参数 ──────────────────────────────────────────────────
SHORT_TERM_MAX_TURNS=10
SHORT_TERM_FORGET_TURNS=2
COMPRESS_TRIGGER=8
MAX_SUMMARY_LENGTH=500

# ── 长期记忆（Qdrant）────────────────────────────────────────
LONGTERM_MEMORY_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=llm_chat_memories
EMBEDDING_DIM=1024
LONGTERM_TOP_K=3
LONGTERM_SCORE_THRESHOLD=0.5
SUMMARY_RELEVANCE_THRESHOLD=0.4

# ── 语义缓存（Redis Search）──────────────────────────────────
SEMANTIC_CACHE_ENABLED=true
REDIS_URL=redis://redis:6379
SEMANTIC_CACHE_INDEX=semantic_cache
SEMANTIC_CACHE_THRESHOLD=0.85
SEMANTIC_CACHE_NAMESPACE_MODE=user
SEMANTIC_CACHE_SEARCH_TTL_HOURS=2

# ── 数据库（PostgreSQL）──────────────────────────────────────
POSTGRES_DB=chatflow
POSTGRES_USER=chatflow
POSTGRES_PASSWORD=chatflow123
DATABASE_URL=ENC(gAAAAABp0e2Vw20BekeIncvNHnq5FGe73JXRQhR6VtCcXIGEmSdTNkHKMxPdDEYCOjRS-Zg-L6lYgYIfmc7JndsnI_QfdVcYEU-zXy945S4IFpjdyni0UOzO4XeAWCcqCeMCg2uHZuliOS-bCQTlP_J3Ek-qZpp0Jg==)

# ── 后端服务 ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_DIR=/var/log/chatflow
CONVERSATIONS_DIR=/app/conversations

# ── Docker 宿主机数据目录 & 端口 ─────────────────────────────
SECRET_DIR=D:/opt/secret
QDRANT_DATA_DIR=D:/docker/qdrant_storage
QDRANT_PORT=6333
POSTGRES_DATA_DIR=D:/docker/postgres_data
POSTGRES_PORT=5432
REDIS_DATA_DIR=D:/docker/redis_data
REDIS_PORT=6379
BACKEND_LOG_HOST_DIR=./logs

# ── MCP 服务器 ────────────────────────────────────────────────
# MCP_SERVERS={"filesystem":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","./data"],"transport":"stdio"}}

TAVILY_API_KEY=ENC(gAAAAABp0e2VyxVlmyUmqYopFfFOYg2cYuOQQ2gNV_rZe72frsdGQ6r5naCiKqjLQzJpzjz9cwcESXStQ8kL06dYjUG1L_uerZjgkqV7jO869zz2GPFrM2FA0a2S36_ppfj908T1H98PsxTXI9J3o-6eGPzjni-BKw==)

# 视觉模型（上传图片时使用，需支持多模态），留空则使用 chat 路由模型
# 示例（Ollama 本地）：qwen2.5vl:7b / llava:13b
VISION_MODEL=qwen2.5vl:7b
# 视觉模型的独立接口地址，默认复用 LLM_BASE_URL
# 示例（Docker 内连 Ollama）：http://host.docker.internal:11434/v1
# 示例（宿主机直接运行）：   http://localhost:11434/v1
VISION_BASE_URL=http://host.docker.internal:11434/v1
# 视觉模型的独立 API Key，默认复用 API_KEY（Ollama 本地填 ollama 即可）
VISION_API_KEY=ollama