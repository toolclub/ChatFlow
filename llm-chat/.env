# ============================================================
# ChatFlow 配置
# ============================================================

# ── 镜像版本控制 ─────────────────────────────────────────────
APP_VERSION=1.0.8

# ── LLM 服务 ─────────────────────────────────────────────────
LLM_BASE_URL=https://api.deepseek.com
API_KEY=ENC(gAAAAABqGCLK-NMMGe11vh1s8BGlNBF86DkXSFFfauohdtbkRiEK2Db3D8laBaiP-niv23FmeAEdjBhjJ-ut9aJbBl6b-IxxkCTSTbQR-BW1zcXE9vWxTYrwTIWNzUuVFZQfBIqSz1h1)
EMBEDDING_BASE_URL=https://ai.gitee.com/v1
EMBEDDING_API_KEY=ENC(gAAAAABqGCLKcFRuVGWzb42rYDEceuU-zA6dpb2S2PDQQnn0ar-JMqphCxdyRMV338LWOQUag2sr6vPB0ra_qS19bB08CwFdqMF2bSINSoBJVRgBI4JPFmHSnGIP3bj2syj78XBNE4gv)

# ── 模型 ─────────────────────────────────────────────────────
CHAT_MODEL=deepseek-v4-pro
SUMMARY_MODEL=deepseek-v4-pro
EMBEDDING_MODEL=Qwen3-Embedding-0.6B
EMBEDDING_FALLBACK_MODELS=["Qwen3-Embedding-8B","Qwen3-Embedding-4B","jina-embeddings-v4","Youtu-Embedding"]

# ── 路由 Agent ────────────────────────────────────────────────
ROUTER_ENABLED=true
ROUTER_MODEL=deepseek-v4-pro
SEARCH_MODEL=deepseek-v4-pro
ROUTE_MODEL_MAP={"code":"deepseek-v4-pro","search":"deepseek-v4-pro","chat":"deepseek-v4-pro","search_code":"deepseek-v4-pro"}

# ── 上下文窗口 ────────────────────────────────────────────────
CHAT_NUM_CTX=8192
SUMMARY_NUM_CTX=4096
FETCH_WEBPAGE_MAX_DISPLAY=500

# ── 记忆参数 ──────────────────────────────────────────────────
SHORT_TERM_MAX_TURNS=10
SHORT_TERM_FORGET_TURNS=2
COMPRESS_TRIGGER=8
MAX_SUMMARY_LENGTH=500

# ── 长期记忆（Qdrant）────────────────────────────────────────
LONGTERM_MEMORY_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=llm_chat_memories
EMBEDDING_DIM=1024
LONGTERM_TOP_K=3
LONGTERM_SCORE_THRESHOLD=0.5
SUMMARY_RELEVANCE_THRESHOLD=0.4

# ── 语义缓存（Redis Search）──────────────────────────────────
SEMANTIC_CACHE_ENABLED=false
REDIS_URL=redis://redis:6379
SEMANTIC_CACHE_INDEX=semantic_cache
SEMANTIC_CACHE_THRESHOLD=0.85
SEMANTIC_CACHE_NAMESPACE_MODE=user
SEMANTIC_CACHE_SEARCH_TTL_HOURS=2

# ── 数据库（PostgreSQL）──────────────────────────────────────
POSTGRES_DB=chatflow
POSTGRES_USER=chatflow
POSTGRES_PASSWORD=chatflow123
DATABASE_URL=ENC(gAAAAABqGCLKZyXAbf3B5iqmAq0HIsQ6hqclpdJmh3KpujN_6XeBrojK83pYi7kuU3YEqUyYKlAHnrFOgl_FUix6sIM-xf-KMdAGnbBWlWXv6X39cRgzV_ArRlckfmdmWQCbkl5BfCkevlemCY2udqE00cFfNwoJQQ==)

# ── 后端服务 ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_DIR=/var/log/chatflow
CONVERSATIONS_DIR=/app/conversations

# ── Docker 宿主机数据目录 & 端口 ─────────────────────────────
SECRET_DIR=D:/opt/secret
QDRANT_DATA_DIR=D:/docker/qdrant_storage
QDRANT_PORT=6333
POSTGRES_DATA_DIR=D:/docker/postgres_data
POSTGRES_PORT=5432
REDIS_DATA_DIR=D:/docker/redis_data
REDIS_PORT=6379
QUANT_CACHE_DATA_DIR=D:/docker/quant_cache
BACKEND_LOG_HOST_DIR=./logs

