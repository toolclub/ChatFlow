# MiniMax 文生图
IMAGE_GEN_ENABLED=true
IMAGE_GEN_BASE_URL=https://api.minimaxi.com/v1
IMAGE_GEN_API_KEY=ENC(gAAAAABqGCLKG9Mi5XF04PENAr2YUx5xdHS0WFgBfx5DgWPG1CsTKa2zayN58dVVnB7rVXZiYfEZgwAHgjmnc4qLHalONcGttSqBAgFka2v69wpaK4dd3cfy7qXvF7AROxqhs2hZ5Nabr7nsOSmJCfJNLTeFxbWwBcpOvAQzy0FB23n9EpTvvDNZs_vyNahA1-51AbAUPR2oJPvrw3imioZwvQpjeXKxX300n1_45GQY6r1oVmgrr-0=)
