JWT_SECRET_KEY=ENC(gAAAAABqGCLK4cg9JMTOgdV2Ktk-MkgW2TElnVzWTcUuFORzhjD2DdKvcz6CSoqlBlxyvSXywIkvVQRQ_vj8yJZCGUU9yPJKAzLsD4h8FvCL3xEzZLsMvu8xUm8j04Rwocf2Ynh4fsSA)
